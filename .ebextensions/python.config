option_settings:
  "aws:elasticbeanstalk:container:python":
    WSGIPath: application:application

Resources:
  AWSEBAutoScalingLaunchConfiguration:
    Type: AWS::AutoScaling::LaunchConfiguration
    Properties:
      BlockDeviceMappings:
        # FIX: Changed the device name to match the modern instance type
        - DeviceName: /dev/xvda
          Ebs:
            VolumeSize: 30
            VolumeType: gp2